# ─── Supabase ──────────────────────────────────────────────
# Obtenlos en: https://app.supabase.com > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Solo para el backend (nunca exponer al frontend)

# ─── Backend API ───────────────────────────────────────────
API_PORT=3001
API_JWT_SECRET=your-super-secret-jwt-key          # Min 32 chars
NODE_ENV=development

# ─── Google Maps ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key      # Web + Mobile

# ─── Firebase (FCM) ────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Desviación de Ruta ────────────────────────────────────
DEVIATION_THRESHOLD_METERS=50                     # Umbral de alerta de desvío
