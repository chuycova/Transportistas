# ─── Supabase (anon key — RLS activo) ─────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Backend NestJS ────────────────────────────────────────────────────────────
# En desarrollo local: http://localhost:3000
# En producción: URL de Railway/Render
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# ─── Google Maps ───────────────────────────────────────────────────────────────
# Estas se inyectan en app.json vía EAS Secrets en producción.
# Para desarrollo local, copia a .env y rellena:
GOOGLE_MAPS_API_KEY_IOS=your-ios-maps-key
GOOGLE_MAPS_API_KEY_ANDROID=your-android-maps-key

# ─── GPS Tracking (defaults) ───────────────────────────────────────────────────
# Intervalo de envío de pings en ms (default 5000 = 5s)
EXPO_PUBLIC_GPS_INTERVAL_MS=5000
# Distancia mínima de movimiento para emitir ping en metros (default 10m)
EXPO_PUBLIC_GPS_DISTANCE_INTERVAL_M=10
