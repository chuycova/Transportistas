{
  "name": "@zona-zero/api",
  "version": "0.0.1",
  "private": true,
  "description": "Backend API — NestJS 11 Modular Monolith (Hexagonal Architecture)",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.0",
    "@supabase/supabase-js": "^2.101.0",
    "@zona-zero/domain": "workspace:*",
    "@zona-zero/infrastructure": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jwks-rsa": "^4.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.10.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^6.0.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.0.0"
  }
}
