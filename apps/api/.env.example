# ─── API CONFIGURATION ────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

# ─── SUPABASE ───────────────────────────────────────────────────────────────────
# URL de tu proyecto de Supabase (ej. https://abcdefgh.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"
# Service Role Key (Para operaciones backend ignorando RLS)
SUPABASE_SERVICE_ROLE_KEY="eyJh...your_key_here"

# ─── AUTENTICACIÓN JWT ────────────────────────────────────────────────────────
# El JWT secret configurado en tu panel de Supabase (Settings > API > JWT Secret)
API_JWT_SECRET="tu_jwt_secret_de_supabase_aqui_minimo_32_caracteres"

# ─── RUTAS Y DESVÍOS ────────────────────────────────────────────────────────────
# Umbral por default en metros para determinar si un vehículo está fuera de ruta
DEVIATION_THRESHOLD_METERS=50

# ─── GOOGLE MAPS (Opcional - útil en futuro si backend necesita Geocoding) ─────
# GOOGLE_MAPS_API_KEY="AIza..."
