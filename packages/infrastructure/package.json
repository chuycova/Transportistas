{
  "name": "@zona-zero/infrastructure",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Infrastructure adapters: Supabase client, HTTP utilities.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "@types/node": "^22.0.0",
    "@zona-zero/domain": "workspace:*"
  }
}
