# pnpm configuration
# Docs: https://pnpm.io/npmrc

# ─── Seguridad Supply Chain ────────────────────────────────────────────────────
# allowlist explícita de paquetes que pueden correr install scripts.
# Equivale a: --ignore-scripts para TODO excepto estos paquetes de confianza.
# Mucho mejor que --ignore-scripts global (que rompe @swc/core, esbuild, turbo).
onlyBuiltDependencies[]=@swc/core
onlyBuiltDependencies[]=@swc/helpers
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=turbo
onlyBuiltDependencies[]=@nestjs/core
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=better-sqlite3
onlyBuiltDependencies[]=canvas

# ─── Integridad de paquetes ────────────────────────────────────────────────────
# Verificar checksums de paquetes descargados
verify-store-integrity=true

# Evitar instalar paquetes con peerDependencies no satisfechas silenciosamente
strict-peer-dependencies=false
auto-install-peers=true

# ─── Workspace ─────────────────────────────────────────────────────────────────
# Evitar instalar dependencias que no están declaradas en el workspace
link-workspace-packages=true
prefer-workspace-packages=true
